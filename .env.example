APP_NAME="My Novel Management System"
APP_DESCRIPTION="a web application specifically designed to manage my entire personal writing ecosystem. It serves as a centralized hub for organizing, tracking, and nurturing my writing projects, ideas, and inspirations. With this system, I can effortlessly manage my novel writing process, from brainstorming and outlining to drafting and editing. It provides a seamless platform to capture and develop my creative ideas, ensuring that no spark of inspiration goes unnoticed. This application is tailored to meet the unique needs of a writer like me, offering tools and features that enhance productivity and foster creativity in my writing journey."
APP_VERSION=1.0.0
APP_AUTHOR="fz-dev"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE="Asia/Jakarta"
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=my_novel_management_system
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=my_novel_management_system_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@my-novel-management-system.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-8b-8192
GROQ_EMBED_MODEL=nomic-embed-text-v1

OLLAMA_URL=http://localhost:11434/api/embeddings
OLLAMA_MODEL=nomic-embed-text

VITE_APP_NAME="${APP_NAME}"

JWT_SECRET=
JWT_TTL=1440
